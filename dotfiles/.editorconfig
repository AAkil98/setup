# ~/.editorconfig — global defaults.
# No `root = true` on purpose: a project's own .editorconfig still wins.

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{js,jsx,ts,tsx,json,jsonc,yml,yaml,toml,css,scss,html,md}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false   # preserve hard line breaks

[Makefile]
indent_style = tab
